# ==========================================
# Конфигурация PostgreSQL
# ==========================================
POSTGRES_USER=admin
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=myapp
POSTGRES_PORT=5432

# ==========================================
# Конфигурация Redis
# ==========================================
REDIS_HOST=redis
REDIS_PORT=6379

# ==========================================
# Конфигурация приложения
# ==========================================
NODE_ENV=production
APP_PORT=3000

# ==========================================
# Версии образов
# ==========================================
REDIS_VERSION=alpine
POSTGRES_VERSION=15-alpine
